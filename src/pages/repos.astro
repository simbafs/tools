---
import Layout from '../layouts/Layout.astro';
---

<Layout title="GitHub Repos Manager">
	<div id="app" class="min-h-[100dvh] bg-zinc-50 dark:bg-zinc-950"></div>
</Layout>

<script>
	import { Octokit } from 'octokit';
	import type { Endpoints } from '@octokit/types';

	type Repo = Endpoints['GET /user/repos']['response']['data'][0];

	type Actions = {
		rename: Record<string, string>;
		archived: Record<string, boolean>;
		private: Record<string, boolean>;
		remove: Record<string, boolean>;
		description: Record<string, string>;
	};

	type Action =
		| { repo: string; action: 'archived' | 'private' | 'remove' }
		| { repo: string; name: string; action: 'rename' }
		| { repo: string; action: 'description'; description: string }
		| { action: 'reset' };

	const clientID = 'Ov23liTnLPEPqqDWdFcE';

	let octokit: Octokit | null = null;
	let repos: Repo[] = [];
	let actions: Actions = {
		rename: {},
		archived: {},
		private: {},
		remove: {},
		description: {},
	};

	let filterName = '';
	let privateFilter = 0;
	let archivedFilter = 0;

	const app = document.getElementById('app')!;

	async function getAllRepos(octokit: Octokit): Promise<Repo[]> {
		return octokit.paginate(`GET /user/repos?sort=created`, {
			'X-GitHub-Api-Version': '2022-11-28',
		});
	}

	function render() {
		if (!octokit) {
			app.innerHTML = `
				<div class="flex min-h-[100dvh] flex-col items-center justify-center p-6">
					<div class="w-full max-w-md text-center">
						<div class="mb-8 flex justify-center">
							<svg class="h-16 w-16 text-zinc-900 dark:text-zinc-100" viewBox="0 0 24 24" fill="currentColor">
								<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
							</svg>
						</div>
						<h1 class="mb-3 text-2xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100">
							GitHub Repos Manager
						</h1>
						<p class="mb-8 text-zinc-500 dark:text-zinc-400">
							Manage multiple repositories at once
						</p>
						<a
							href="https://github.com/login/oauth/authorize?client_id=${clientID}&scope=repo+delete_repo"
							class="inline-flex items-center gap-2 rounded-full bg-zinc-900 px-6 py-3 text-sm font-medium text-white transition-all duration-300 hover:bg-zinc-800 hover:-translate-y-0.5 active:translate-y-0 dark:bg-zinc-100 dark:text-zinc-900 dark:hover:bg-zinc-200"
						>
							<svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
								<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
							</svg>
							Sign in with GitHub
						</a>
					</div>
				</div>
			`;
			return;
		}

		if (repos.length === 0) {
			app.innerHTML = `
				<div class="flex min-h-[100dvh] flex-col items-center justify-center p-6">
					<div class="w-full max-w-2xl">
						<div class="mb-6 flex items-center justify-between">
							<h1 class="text-2xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100">
								Repositories
							</h1>
							<span class="text-sm text-zinc-500">${repos.length} repos</span>
						</div>
						${renderLoadingSkeleton()}
					</div>
				</div>
			`;
			return;
		}

		renderMain();
	}

	function renderLoadingSkeleton() {
		return `
			<div class="space-y-3">
				${Array(5).fill(0).map(() => `
					<div class="flex gap-4 p-4">
						<div class="h-6 w-1/3 animate-pulse rounded bg-zinc-200 dark:bg-zinc-800"></div>
						<div class="h-6 w-1/4 animate-pulse rounded bg-zinc-200 dark:bg-zinc-800"></div>
						<div class="h-6 w-20 animate-pulse rounded bg-zinc-200 dark:bg-zinc-800"></div>
						<div class="h-6 w-20 animate-pulse rounded bg-zinc-200 dark:bg-zinc-800"></div>
						<div class="h-6 w-16 animate-pulse rounded bg-zinc-200 dark:bg-zinc-800"></div>
					</div>
				`).join('')}
			</div>
		`;
	}

	function renderMain() {
		const filtered = filterRepos(repos);
		const pendingCount = Object.keys(actions.rename).length +
			Object.keys(actions.archived).length +
			Object.keys(actions.private).length +
			Object.keys(actions.remove).length +
			Object.keys(actions.description).length;

		app.innerHTML = `
			<div class="mx-auto max-w-7xl p-6">
				<header class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
					<div>
						<h1 class="text-2xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100">
							Repositories
						</h1>
						<p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">
							${repos.length} repos - ${filtered.length} shown
							${pendingCount > 0 ? `<span class="ml-2 inline-flex items-center rounded-full bg-emerald-100 px-2 py-0.5 text-xs font-medium text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400">${pendingCount} pending</span>` : ''}
						</p>
					</div>
					<div class="flex gap-3">
						${pendingCount > 0 ? `
							<button id="reset-btn" class="inline-flex items-center gap-2 rounded-full border border-zinc-300 bg-white px-4 py-2 text-sm font-medium text-zinc-700 transition-all duration-200 hover:bg-zinc-50 hover:-translate-y-0.5 active:translate-y-0 dark:border-zinc-700 dark:bg-zinc-800 dark:text-zinc-300 dark:hover:bg-zinc-700">
								<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
									<path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
								</svg>
								Reset
							</button>
						` : ''}
						<button id="submit-btn" class="inline-flex items-center gap-2 rounded-full bg-emerald-600 px-5 py-2 text-sm font-medium text-white transition-all duration-200 hover:bg-emerald-700 hover:-translate-y-0.5 active:translate-y-0 ${pendingCount === 0 ? 'opacity-50 cursor-not-allowed' : ''}" ${pendingCount === 0 ? 'disabled' : ''}>
							<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
							</svg>
							Apply Changes
						</button>
					</div>
				</header>

				<div class="mb-6 overflow-auto rounded-2xl border border-zinc-200 bg-white dark:border-zinc-800 dark:bg-zinc-900 max-h-[calc(100dvh-200px)]">
					${renderFilterRow()}
					${filtered.length > 0 ? filtered.map((repo, i) => renderRepoRow(repo, i)).join('') : renderEmptyState()}
				</div>
			</div>
		`;

		attachEventListeners();
	}

	function renderFilterRow() {
		const privateState = ['all', 'private', 'public'];
		const archivedState = ['all', 'archived', 'unarchived'];

		return `
			<div class="sticky top-0 z-10">
				<div class="grid grid-cols-[2fr_2fr_7rem_7rem_5rem] divide-x divide-zinc-200 border-b border-zinc-200 bg-zinc-100 dark:divide-zinc-800 dark:border-zinc-800 dark:bg-zinc-800/50">
					<div class="p-2 text-center text-xs font-medium uppercase tracking-wider text-zinc-500 dark:text-zinc-400">Repository</div>
					<div class="p-2 text-center text-xs font-medium uppercase tracking-wider text-zinc-500 dark:text-zinc-400">Description</div>
					<div class="p-2 text-center text-xs font-medium uppercase tracking-wider text-zinc-500 dark:text-zinc-400">Visibility</div>
					<div class="p-2 text-center text-xs font-medium uppercase tracking-wider text-zinc-500 dark:text-zinc-400">Status</div>
					<div class="p-2 text-center text-xs font-medium uppercase tracking-wider text-zinc-500 dark:text-zinc-400"></div>
				</div>
				<div class="grid grid-cols-[2fr_2fr_7rem_7rem_5rem] divide-x divide-zinc-200 bg-zinc-50 shadow-sm dark:divide-zinc-800 dark:bg-zinc-900/50 dark:shadow-zinc-950/50">
					<div class="p-3">
						<input
							type="text"
							id="filter-name"
							value="${filterName}"
							placeholder="Filter by name..."
							class="w-full rounded-lg border-0 bg-white px-3 py-2 text-sm text-zinc-900 ring-1 ring-zinc-200 placeholder:text-zinc-400 focus:ring-2 focus:ring-emerald-500 dark:bg-zinc-800 dark:text-zinc-100 dark:ring-zinc-700 dark:placeholder:text-zinc-500"
						/>
					</div>
					<div class="p-3"></div>
					<button id="toggle-private" class="flex items-center justify-center px-2 py-2 text-sm font-medium transition-colors hover:bg-zinc-100 dark:hover:bg-zinc-800">
						<span class="rounded-full px-3 py-1 ${privateFilter !== 0 ? 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400' : 'text-zinc-600 dark:text-zinc-400'}">
							${privateState[privateFilter]}
						</span>
					</button>
					<button id="toggle-archived" class="flex items-center justify-center px-2 py-2 text-sm font-medium transition-colors hover:bg-zinc-100 dark:hover:bg-zinc-800">
						<span class="rounded-full px-3 py-1 ${archivedFilter !== 0 ? 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400' : 'text-zinc-600 dark:text-zinc-400'}">
							${archivedState[archivedFilter]}
						</span>
					</button>
					<div class="flex items-center justify-center px-2 py-2 text-sm font-medium text-zinc-600 dark:text-zinc-400"></div>
				</div>
			</div>
		`;
	}

	function renderRepoRow(repo: Repo, index: number) {
		const isPendingRename = repo.full_name in actions.rename;
		const isPendingDesc = repo.full_name in actions.description;
		const isPendingPrivate = repo.full_name in actions.private;
		const isPendingArchive = repo.full_name in actions.archived;
		const isPendingRemove = repo.full_name in actions.remove;

		const hasPending = isPendingRename || isPendingDesc || isPendingPrivate || isPendingArchive || isPendingRemove;

		return `
			<div class="group grid grid-cols-[2fr_2fr_7rem_7rem_5rem] divide-x divide-zinc-200 border-t border-zinc-200 transition-colors hover:bg-zinc-50 dark:divide-zinc-800 dark:border-zinc-800 dark:hover:bg-zinc-800/50 ${hasPending ? 'bg-amber-50/50 dark:bg-amber-950/10' : ''}" style="animation-delay: calc(${index} * 20ms)">
				<div class="group/cell relative p-3 cursor-pointer" data-action="rename" data-repo="${repo.full_name}">
					<div class="flex items-center gap-2">
						<svg class="h-4 w-4 flex-shrink-0 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
						</svg>
						<div class="min-w-0">
							<a href="${repo.html_url}" target="_blank" class="block truncate text-sm font-medium text-zinc-900 hover:text-emerald-600 dark:text-zinc-100 dark:hover:text-emerald-400">
								${repo.full_name}
							</a>
							${isPendingRename ? `
								<span class="text-xs font-medium text-amber-600 dark:text-amber-400">
									-&gt; ${actions.rename[repo.full_name]}
								</span>
							` : ''}
						</div>
					</div>
				</div>

				<div class="group/cell relative p-3 cursor-pointer" data-action="description" data-repo="${repo.full_name}">
					<p class="line-clamp-2 text-sm text-zinc-500 dark:text-zinc-400 ${repo.description ? '' : 'italic'}">
						${repo.description || 'No description'}
					</p>
					${isPendingDesc ? `
						<span class="text-xs font-medium text-amber-600 dark:text-amber-400">
							-&gt; ${actions.description[repo.full_name] || '(empty)'}
						</span>
					` : ''}
				</div>

				<button
					class="flex flex-col items-center justify-center gap-1 p-2 text-xs font-medium transition-colors hover:bg-zinc-100 dark:hover:bg-zinc-800"
					data-action="private"
					data-repo="${repo.full_name}"
				>
					<span class="flex h-6 w-6 items-center justify-center rounded-full ${repo.private ? 'bg-zinc-900 text-white dark:bg-zinc-100 dark:text-zinc-900' : 'bg-zinc-200 text-zinc-600 dark:bg-zinc-700 dark:text-zinc-300'}">
						${repo.private ? `
							<svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
								<path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
							</svg>
						` : `
							<svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
							</svg>
						`}
					</span>
					${isPendingPrivate ? `<span class="text-amber-600 dark:text-amber-400">-&gt;${actions.private[repo.full_name] ? 'P' : 'O'}</span>` : ''}
				</button>

				<button
					class="flex flex-col items-center justify-center gap-1 p-2 text-xs font-medium transition-colors hover:bg-zinc-100 dark:hover:bg-zinc-800"
					data-action="archived"
					data-repo="${repo.full_name}"
				>
					<span class="flex h-6 w-6 items-center justify-center rounded-full ${repo.archived ? 'bg-zinc-600 text-white' : 'bg-zinc-200 text-zinc-500 dark:bg-zinc-700 dark:text-zinc-400'}">
						${repo.archived ? `
							<svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
							</svg>
						` : ''}
					</span>
					${isPendingArchive ? `<span class="text-amber-600 dark:text-amber-400">-&gt;${actions.archived[repo.full_name] ? 'A' : 'U'}</span>` : ''}
				</button>

				<button
					class="flex items-center justify-center p-2 transition-colors hover:bg-red-50 dark:hover:bg-red-950/30"
					data-action="remove"
					data-repo="${repo.full_name}"
				>
					${isPendingRemove ? `
						<span class="flex h-6 w-6 items-center justify-center rounded-full bg-red-500 text-white">
							<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
							</svg>
						</span>
					` : `
						<span class="flex h-6 w-6 items-center justify-center rounded-full border border-zinc-300 text-zinc-300 hover:border-red-300 hover:text-red-400 dark:border-zinc-700 dark:text-zinc-600">
							<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
							</svg>
						</span>
					`}
				</button>
			</div>
		`;
	}

	function renderEmptyState() {
		return `
			<div class="flex flex-col items-center justify-center py-16 text-center">
				<svg class="h-12 w-12 text-zinc-300 dark:text-zinc-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
					<path stroke-linecap="round" stroke-linejoin="round" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
				</svg>
				<p class="mt-4 text-sm text-zinc-500 dark:text-zinc-400">No repositories match your filters</p>
			</div>
		`;
	}

	function filterRepos(allRepos: Repo[]) {
		return allRepos.filter((repo) => {
			if (filterName && !repo.full_name.match(filterName)) return false;
			if (privateFilter !== 0) {
				const isPrivate = privateFilter === 1 ? repo.private : !repo.private;
				if (!isPrivate) return false;
			}
			if (archivedFilter !== 0) {
				const isArchived = archivedFilter === 1 ? repo.archived : !repo.archived;
				if (!isArchived) return false;
			}
			return true;
		});
	}

	function updateActions(action: Action) {
		if (action.action === 'reset') {
			actions = {
				rename: {},
				archived: {},
				private: {},
				remove: {},
				description: {},
			};
			render();
			return;
		}

		const repo = repos.find((r) => r.full_name === action.repo);
		if (!repo) return;

		const newActions = { ...actions };

		switch (action.action) {
			case 'rename':
				newActions.rename[action.repo] = action.name;
				if (action.name === repo.full_name) delete newActions.rename[action.repo];
				break;
			case 'private':
				const isPrivate = action.repo in newActions.private
					? !newActions.private[action.repo]
					: !repo.private;
				newActions.private[action.repo] = isPrivate;
				if (isPrivate === repo.private) delete newActions.private[action.repo];
				break;
			case 'archived':
				const archived = action.repo in newActions.archived
					? !newActions.archived[action.repo]
					: !repo.archived;
				newActions.archived[action.repo] = archived;
				if (archived === repo.archived) delete newActions.archived[action.repo];
				break;
			case 'remove':
				const remove = action.repo in newActions.remove
					? !newActions.remove[action.repo]
					: true;
				newActions.remove[action.repo] = remove;
				if (!remove) delete newActions.remove[action.repo];
				break;
			case 'description':
				newActions.description[action.repo] = action.description;
				if (action.description === repo.description) delete newActions.description[action.repo];
				break;
		}

		actions = newActions;
		render();
	}

	function composeMsg(): string {
		const s: string[] = [];

		const toBeRemoved = Object.keys(actions.remove).map((repoName) => {
			const [owner, repo] = repoName.split('/');
			return { owner, repo };
		});

		const reposToUpdate = [
			...new Set([
				...Object.keys(actions.private),
				...Object.keys(actions.archived),
				...Object.keys(actions.rename),
				...Object.keys(actions.description),
			]),
		].map((repoName) => {
			const [owner, repo] = repoName.split('/');
			const r: { owner: string; repo: string; private?: boolean; archived?: boolean; name?: string; description?: string } = { owner, repo };

			if (repoName in actions.private) {
				r.private = actions.private[repoName];
			}
			if (repoName in actions.archived) {
				r.archived = actions.archived[repoName];
			}
			if (repoName in actions.rename) {
				r.name = actions.rename[repoName];
			}
			if (repoName in actions.description) {
				r.description = actions.description[repoName];
			}

			return r;
		});

		for (const repo of reposToUpdate) {
			const actionParts: string[] = [];
			if (repo.archived !== undefined) {
				actionParts.push(repo.archived ? '封存' : '解封存');
			}
			if (repo.private !== undefined) {
				actionParts.push(repo.private ? '設為私人' : '公開');
			}
			if (repo.description !== undefined) {
				actionParts.push(repo.description ? '更改描述' : '清除描述');
			}
			if (repo.name) {
				actionParts.push(`改名為 ${repo.name}`);
			}

			s.push(actionParts.join('、') + `${repo.owner}/${repo.repo}`);
		}

		for (const repo of toBeRemoved) {
			s.push(`刪除 ${repo.owner}/${repo.repo}`);
		}

		return s.join('\n');
	}

	async function doAction() {
		const toBeRemoved = Object.keys(actions.remove).map((repoName) => {
			const [owner, repo] = repoName.split('/');
			return { owner, repo };
		});

		const reposToUpdate = [
			...new Set([
				...Object.keys(actions.private),
				...Object.keys(actions.archived),
				...Object.keys(actions.rename),
				...Object.keys(actions.description),
			]),
		].map((repoName) => {
			const [owner, repo] = repoName.split('/');
			const r: { owner: string; repo: string; private?: boolean; archived?: boolean; name?: string; description?: string } = { owner, repo };

			if (repoName in actions.private) {
				r.private = actions.private[repoName];
			}
			if (repoName in actions.archived) {
				r.archived = actions.archived[repoName];
			}
			if (repoName in actions.rename) {
				r.name = actions.rename[repoName];
			}
			if (repoName in actions.description) {
				r.description = actions.description[repoName];
			}

			return r;
		});

		await Promise.all(
			reposToUpdate.map((repo) => octokit!.request(`PATCH /repos/{owner}/{repo}`, repo)),
		);

		await Promise.all(
			toBeRemoved.map((repo) => octokit!.request('DELETE /repos/{owner}/{repo}', repo)),
		);
	}

	function attachEventListeners() {
		const filterNameInput = document.getElementById('filter-name') as HTMLInputElement;
		if (filterNameInput) {
			filterNameInput.addEventListener('input', (e) => {
				filterName = (e.target as HTMLInputElement).value;
				renderMain();
			});
		}

		const togglePrivate = document.getElementById('toggle-private');
		if (togglePrivate) {
			togglePrivate.addEventListener('click', () => {
				privateFilter = (privateFilter + 1) % 3;
				renderMain();
			});
		}

		const toggleArchived = document.getElementById('toggle-archived');
		if (toggleArchived) {
			toggleArchived.addEventListener('click', () => {
				archivedFilter = (archivedFilter + 1) % 3;
				renderMain();
			});
		}

		document.querySelectorAll('[data-action="rename"]').forEach((el) => {
			el.addEventListener('dblclick', () => {
				const repoFullName = el.getAttribute('data-repo')!;
				const name = repoFullName.split('/')[1];
				const newName = prompt(`Rename ${name}`, name);
				if (newName) {
					const owner = repoFullName.split('/')[0];
					updateActions({ repo: repoFullName, name: `${owner}/${newName}`, action: 'rename' });
				}
			});
		});

		document.querySelectorAll('[data-action="description"]').forEach((el) => {
			el.addEventListener('dblclick', () => {
				const repoFullName = el.getAttribute('data-repo')!;
				const repo = repos.find((r) => r.full_name === repoFullName);
				const newDesc = prompt(`Set Description`, repo?.description || '');
				updateActions({ repo: repoFullName, action: 'description', description: newDesc || repo?.description || '' });
			});
		});

		document.querySelectorAll('[data-action="private"]').forEach((el) => {
			el.addEventListener('click', () => {
				const repoFullName = el.getAttribute('data-repo')!;
				updateActions({ repo: repoFullName, action: 'private' });
			});
		});

		document.querySelectorAll('[data-action="archived"]').forEach((el) => {
			el.addEventListener('click', () => {
				const repoFullName = el.getAttribute('data-repo')!;
				updateActions({ repo: repoFullName, action: 'archived' });
			});
		});

		document.querySelectorAll('[data-action="remove"]').forEach((el) => {
			el.addEventListener('click', () => {
				const repoFullName = el.getAttribute('data-repo')!;
				updateActions({ repo: repoFullName, action: 'remove' });
			});
		});

		const resetBtn = document.getElementById('reset-btn');
		if (resetBtn) {
			resetBtn.addEventListener('click', () => {
				updateActions({ action: 'reset' });
			});
		}

		const submitBtn = document.getElementById('submit-btn');
		if (submitBtn) {
			submitBtn.addEventListener('click', async () => {
				const msg = composeMsg();
				if (!msg) {
					alert('No changes to apply');
					return;
				}
				if (!confirm(msg)) return;
				if (!confirm('確定要執行？不可回復喔！')) return;
				if (!confirm('真的嗎？這是最後一次確認')) return;

				try {
					await doAction();
					alert('ok，請自己重新整理頁面，有時候要稍等一下才會抓到最新狀態');
					updateActions({ action: 'reset' });
				} catch (e) {
					alert('error\n' + (e as Error).message);
					console.error(e);
				}
			});
		}
	}

	const urlParams = new URLSearchParams(window.location.search);
	const code = urlParams.get('code');

	if (code) {
		fetch('/api/auth/github', {
			method: 'POST',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify({ code }),
		})
			.then((res) => res.json())
			.then((data) => {
				octokit = new Octokit({ auth: data.access_token });
				getAllRepos(octokit).then((r) => {
					repos = r;
					render();
				});
			})
			.then(() => {
				window.history.replaceState(null, '', '/repos');
			})
			.catch((e) => {
				alert('登入失敗，錯誤訊息在 Console');
				console.error(e);
			});
	} else {
		render();
	}
</script>
