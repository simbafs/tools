---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Flexible Timer">
	<div class="fixed inset-0 flex items-center justify-center bg-zinc-50 dark:bg-zinc-950">
		<div id="display-value" class="w-full px-4 text-center font-bold leading-tight tracking-tight text-zinc-900 dark:text-zinc-50 text-balance">
			請先完成設定
		</div>
	</div>

	<div id="display-meta" class="fixed bottom-8 left-0 right-0 text-center text-sm text-zinc-500 dark:text-zinc-400">
		尚未指定時間點
	</div>

	<div id="done-behavior-hint" class="fixed bottom-8 left-0 right-0 text-center text-xs text-zinc-400 dark:text-zinc-500 hidden">
		已達時間點
	</div>

	<button id="edit-config-btn" type="button" class="fixed top-4 right-4 z-40 rounded-xl bg-zinc-200/80 p-3 text-zinc-600 backdrop-blur-sm transition hover:bg-zinc-300 dark:bg-zinc-800/80 dark:text-zinc-300 dark:hover:bg-zinc-700" title="設定">
		<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1a2 2 0 0 0 2.73V20 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
	</button>

	<dialog id="config-dialog" class="m-auto max-h-[90vh] overflow-y-auto rounded-3xl border border-zinc-200/50 bg-white p-8 shadow-[0_20px_40px_-15px_rgba(0,0,0,0.1)] backdrop:bg-black/30 dark:border-zinc-700/50 dark:bg-zinc-900 [&::backdrop]:bg-black/50 [&::backdrop]:backdrop-blur-sm">
		<div class="mb-8 flex items-start justify-between sticky top-0 bg-white dark:bg-zinc-900 pb-4 -mx-8 px-8 border-b border-zinc-100 dark:border-zinc-800">
			<div>
				<h1 class="text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-50">計時器設定</h1>
				<p class="mt-1 text-sm text-zinc-500 dark:text-zinc-400">
					設定會立即生效，無需確認
				</p>
			</div>
			<button type="button" id="close-config-btn" class="p-2 hover:bg-zinc-100 dark:hover:bg-zinc-800 rounded-xl transition" title="關閉">
				<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
			</button>
		</div>

		<div class="space-y-8">
			<div>
				<label class="mb-3 block text-sm font-semibold text-zinc-900 dark:text-zinc-50">設定方式</label>
				<div class="grid grid-cols-2 gap-2 rounded-2xl bg-zinc-100 p-1 dark:bg-zinc-800">
					<button id="method-point-btn" type="button" class="method-btn rounded-xl px-4 py-2.5 text-sm font-medium transition data-[active=true]:bg-white data-[active=true]:shadow-sm dark:data-[active=true]:bg-zinc-700" data-method="point" data-active="true">
						指定時間點
					</button>
					<button id="method-duration-btn" type="button" class="method-btn rounded-xl px-4 py-2.5 text-sm font-medium transition data-[active=true]:bg-white data-[active=true]:shadow-sm dark:data-[active=true]:bg-zinc-700" data-method="duration" data-active="false">
						倒數一段時間
					</button>
				</div>
			</div>

			<div id="panel-point" class="space-y-4">
				<div>
					<label for="point-input" class="mb-2 block text-sm font-semibold text-zinc-900 dark:text-zinc-50">時間點</label>
					<input id="point-input" type="datetime-local" class="w-full rounded-xl border border-zinc-300 bg-white px-4 py-3 text-sm outline-none transition focus:border-emerald-500 focus:ring-4 focus:ring-emerald-500/15 dark:border-zinc-700 dark:bg-zinc-950 dark:focus:border-emerald-400" />
				</div>
				<p class="text-xs leading-6 text-zinc-500 dark:text-zinc-400">
					輸入未來時間會變成倒數；輸入現在或過去時間會變成正數。
				</p>
			</div>

			<div id="panel-duration" class="hidden space-y-4">
				<div>
					<label class="mb-3 block text-sm font-semibold text-zinc-900 dark:text-zinc-50">倒數長度</label>
					<div class="grid grid-cols-8 gap-2">
						<div>
							<input id="dur-year" type="number" min="0" placeholder="0" class="w-full rounded-xl border border-zinc-300 bg-white px-3 py-2.5 text-center text-sm outline-none transition focus:border-emerald-500 focus:ring-4 focus:ring-emerald-500/15 dark:border-zinc-700 dark:bg-zinc-950 dark:focus:border-emerald-400" />
							<div class="mt-1 text-center text-xs font-medium text-zinc-600 dark:text-zinc-400">年</div>
						</div>
						<div>
							<input id="dur-month" type="number" min="0" placeholder="0" class="w-full rounded-xl border border-zinc-300 bg-white px-3 py-2.5 text-center text-sm outline-none transition focus:border-emerald-500 focus:ring-4 focus:ring-emerald-500/15 dark:border-zinc-700 dark:bg-zinc-950 dark:focus:border-emerald-400" />
							<div class="mt-1 text-center text-xs font-medium text-zinc-600 dark:text-zinc-400">月</div>
						</div>
						<div>
							<input id="dur-week" type="number" min="0" placeholder="0" class="w-full rounded-xl border border-zinc-300 bg-white px-3 py-2.5 text-center text-sm outline-none transition focus:border-emerald-500 focus:ring-4 focus:ring-emerald-500/15 dark:border-zinc-700 dark:bg-zinc-950 dark:focus:border-emerald-400" />
							<div class="mt-1 text-center text-xs font-medium text-zinc-600 dark:text-zinc-400">週</div>
						</div>
						<div>
							<input id="dur-day" type="number" min="0" placeholder="0" class="w-full rounded-xl border border-zinc-300 bg-white px-3 py-2.5 text-center text-sm outline-none transition focus:border-emerald-500 focus:ring-4 focus:ring-emerald-500/15 dark:border-zinc-700 dark:bg-zinc-950 dark:focus:border-emerald-400" />
							<div class="mt-1 text-center text-xs font-medium text-zinc-600 dark:text-zinc-400">日</div>
						</div>
						<div>
							<input id="dur-hour" type="number" min="0" placeholder="0" class="w-full rounded-xl border border-zinc-300 bg-white px-3 py-2.5 text-center text-sm outline-none transition focus:border-emerald-500 focus:ring-4 focus:ring-emerald-500/15 dark:border-zinc-700 dark:bg-zinc-950 dark:focus:border-emerald-400" />
							<div class="mt-1 text-center text-xs font-medium text-zinc-600 dark:text-zinc-400">時</div>
						</div>
						<div>
							<input id="dur-minute" type="number" min="0" placeholder="0" class="w-full rounded-xl border border-zinc-300 bg-white px-3 py-2.5 text-center text-sm outline-none transition focus:border-emerald-500 focus:ring-4 focus:ring-emerald-500/15 dark:border-zinc-700 dark:bg-zinc-950 dark:focus:border-emerald-400" />
							<div class="mt-1 text-center text-xs font-medium text-zinc-600 dark:text-zinc-400">分</div>
						</div>
						<div>
							<input id="dur-second" type="number" min="0" placeholder="0" class="w-full rounded-xl border border-zinc-300 bg-white px-3 py-2.5 text-center text-sm outline-none transition focus:border-emerald-500 focus:ring-4 focus:ring-emerald-500/15 dark:border-zinc-700 dark:bg-zinc-950 dark:focus:border-emerald-400" />
							<div class="mt-1 text-center text-xs font-medium text-zinc-600 dark:text-zinc-400">秒</div>
						</div>
						<div>
							<input id="dur-ms" type="number" min="0" placeholder="0" class="w-full rounded-xl border border-zinc-300 bg-white px-3 py-2.5 text-center text-sm outline-none transition focus:border-emerald-500 focus:ring-4 focus:ring-emerald-500/15 dark:border-zinc-700 dark:bg-zinc-950 dark:focus:border-emerald-400" />
							<div class="mt-1 text-center text-xs font-medium text-zinc-600 dark:text-zinc-400">毫秒</div>
						</div>
					</div>
				</div>

				<p class="text-xs leading-6 text-zinc-500 dark:text-zinc-400">
					底層會轉換成「現在之後的某個時間點」。月份與年份會以日曆方式遞增。
				</p>
			</div>

			<div>
				<label class="mb-4 block text-sm font-semibold text-zinc-900 dark:text-zinc-50">顯示格式設定</label>
				
				<div class="mb-6 pb-6 border-b border-zinc-200 dark:border-zinc-800">
					<label class="mb-3 block text-xs font-semibold tracking-wide uppercase text-zinc-600 dark:text-zinc-400">快速預設</label>
					<div id="preset-buttons" class="grid grid-cols-6 gap-2">
						<button id="preset-btn-1" type="button" class="preset-btn rounded-xl border border-zinc-300 bg-white px-3 py-2.5 text-xs font-medium transition hover:border-emerald-400 hover:bg-emerald-50 dark:border-zinc-700 dark:bg-zinc-800 dark:hover:border-emerald-500 dark:hover:bg-zinc-700" data-preset="preset1">
							完整格式
						</button>
						<button id="preset-btn-2" type="button" class="preset-btn rounded-xl border border-zinc-300 bg-white px-3 py-2.5 text-xs font-medium transition hover:border-emerald-400 hover:bg-emerald-50 dark:border-zinc-700 dark:bg-zinc-800 dark:hover:border-emerald-500 dark:hover:bg-zinc-700" data-preset="preset2">
							斜線格式
						</button>
						<button id="preset-btn-3" type="button" class="preset-btn rounded-xl border border-zinc-300 bg-white px-3 py-2.5 text-xs font-medium transition hover:border-emerald-400 hover:bg-emerald-50 dark:border-zinc-700 dark:bg-zinc-800 dark:hover:border-emerald-500 dark:hover:bg-zinc-700" data-preset="preset3">
							簡短格式
						</button>
						<button id="preset-btn-4" type="button" class="preset-btn rounded-xl border border-zinc-300 bg-white px-3 py-2.5 text-xs font-medium transition hover:border-emerald-400 hover:bg-emerald-50 dark:border-zinc-700 dark:bg-zinc-800 dark:hover:border-emerald-500 dark:hover:bg-zinc-700" data-preset="preset4">
							時分秒
						</button>
						<button id="preset-btn-5" type="button" class="preset-btn rounded-xl border border-zinc-300 bg-white px-3 py-2.5 text-xs font-medium transition hover:border-emerald-400 hover:bg-emerald-50 dark:border-zinc-700 dark:bg-zinc-800 dark:hover:border-emerald-500 dark:hover:bg-zinc-700" data-preset="preset5">
							僅日期
						</button>
						<button id="preset-btn-6" type="button" class="preset-btn rounded-xl border border-zinc-300 bg-white px-3 py-2.5 text-xs font-medium transition hover:border-emerald-400 hover:bg-emerald-50 dark:border-zinc-700 dark:bg-zinc-800 dark:hover:border-emerald-500 dark:hover:bg-zinc-700" data-preset="preset6">
							僅毫秒
						</button>
					</div>
				</div>

				<div>
					<label class="mb-4 block text-xs font-semibold tracking-wide uppercase text-zinc-600 dark:text-zinc-400">自訂單位範本</label>
					<div id="display-settings-grid" class="grid grid-cols-2 md:grid-cols-4 gap-3"></div>
				</div>
				
				<p class="text-xs leading-6 text-zinc-500 dark:text-zinc-400">
					支援的 Token：%Y (年) · %M (月) · %W (週) · %D (日) · %h (時,2位) · %m (分,2位) · %s (秒,2位) · %ms (毫秒,3位)
				</p>
			</div>

			<div>
				<label class="mb-4 block text-sm font-semibold text-zinc-900 dark:text-zinc-50">倒數結束時</label>
				<div class="space-y-4">
					<div class="grid grid-cols-2 gap-2">
						<label class="finish-mode-card"><input type="radio" name="finish-mode" value="countup" checked /> <span>轉成正數</span></label>
						<label class="finish-mode-card"><input type="radio" name="finish-mode" value="stop" /> <span>停下</span></label>
					</div>

					<div id="stop-behavior-wrap" class="hidden">
						<label class="mb-3 block text-xs font-semibold tracking-wide text-zinc-600 dark:text-zinc-400">停下後顯示方式</label>
						<div class="grid grid-cols-3 gap-2">
							<label class="finish-mode-card text-sm"><input type="radio" name="stop-behavior" value="freeze" checked /> <span>閃爍</span></label>
							<label class="finish-mode-card text-sm"><input type="radio" name="stop-behavior" value="zero" /> <span>歸零</span></label>
							<label class="finish-mode-card text-sm"><input type="radio" name="stop-behavior" value="reset" /> <span>重置</span></label>
						</div>
					</div>
				</div>
			</div>

			<div class="flex gap-3 pt-4 border-t border-zinc-200 dark:border-zinc-800 mt-8">
				<button id="reset-btn" type="button" class="flex-1 rounded-xl border border-zinc-300 bg-white px-4 py-2.5 text-sm font-semibold text-zinc-900 transition hover:bg-zinc-100 dark:border-zinc-700 dark:bg-zinc-800 dark:text-zinc-50 dark:hover:bg-zinc-700">
					重設設定
				</button>
			</div>
		</div>
	</dialog>
</Layout>

<style is:global>
	.unit-chip,
	.finish-mode-card {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.45rem;
		border-radius: 1rem;
		border: 1px solid rgb(212 212 216);
		background: white;
		padding: 0.7rem 0.8rem;
		font-size: 0.875rem;
		font-weight: 600;
		cursor: pointer;
		transition: 180ms ease;
		user-select: none;
	}

	.dark .unit-chip,
	.dark .finish-mode-card {
		border-color: rgb(63 63 70);
		background: rgb(24 24 27);
	}

	.unit-chip:has(input:checked),
	.finish-mode-card:has(input:checked) {
		border-color: rgb(59 130 246);
		box-shadow: 0 0 0 4px rgb(59 130 246 / 0.12);
		color: rgb(37 99 235);
	}

	.dark .unit-chip:has(input:checked),
	.dark .finish-mode-card:has(input:checked) {
		color: rgb(147 197 253);
	}

	.unit-chip input,
	.finish-mode-card input {
		accent-color: rgb(59 130 246);
	}

	.preset-btn {
		font-size: 0.75rem;
		font-weight: 500;
		transition: all 150ms ease;
	}

	.preset-btn:active {
		scale: 0.97;
	}

	.preset-btn[data-active="true"] {
		border-color: rgb(16 185 129);
		background: rgb(16 185 129);
		color: white;
		box-shadow: 0 0 0 4px rgb(16 185 129 / 0.1);
	}

	.dark .preset-btn[data-active="true"] {
		border-color: rgb(16 185 129);
		background: rgb(16 185 129);
		color: white;
		box-shadow: 0 0 0 4px rgb(16 185 129 / 0.15);
	}

	.display-settings-item {
		display: grid;
		grid-template-columns: auto min-content;
		gap: 0.55rem;
		border-radius: 0.875rem;
		border: 1px solid rgb(229 231 235);
		background: rgb(249 250 251);
		padding: 0.875rem;
		transition: all 150ms ease;
		min-width: 0;
	}

	.display-settings-item:hover {
		border-color: rgb(209 213 219);
		background: rgb(245 247 250);
	}

	.dark .display-settings-item {
		border-color: rgb(63 63 70);
		background: rgb(24 24 27);
	}

	.dark .display-settings-item:hover {
		border-color: rgb(82 82 91);
		background: rgb(39 39 42);
	}

	.display-settings-item > label:first-child {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.8125rem;
		font-weight: 600;
		cursor: pointer;
		text-wrap: nowrap;
	}

	.display-settings-item input[type="checkbox"] {
		accent-color: rgb(16 185 129);
		cursor: pointer;
		flex-shrink: 0;
	}

	.display-settings-item input[type="text"] {
		grid-column: 1/3;
		box-sizing: border-box;
		border-radius: 0.625rem;
		border: 1px solid rgb(209 213 219);
		background: white;
		padding: 0.4rem 0.6rem;
		font-size: 0.75rem;
		font-family: ui-monospace, 'Courier New', monospace;
		outline: none;
		transition: all 150ms ease;
	}

	.dark .display-settings-item input[type="text"] {
		border-color: rgb(82 82 91);
		background: rgb(39 39 42);
		color: rgb(228 228 231);
	}

	.display-settings-item input[type="text"]:focus {
		border-color: rgb(16 185 129);
		box-shadow: 0 0 0 3px rgb(16 185 129 / 0.1);
	}

	.display-settings-break {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		font-size: 0.75rem;
		color: rgb(82 82 91);
		cursor: pointer;
		user-select: none;
	}

	.dark .display-settings-break {
		color: rgb(161 161 170);
	}

	@keyframes blink-timer {
		0%, 100% { opacity: 1; }
		50% { opacity: 0.18; }
	}

	.blinking {
		animation: blink-timer 0.9s step-end infinite;
	}

	#display-value {
		font-size: 12vw;
		font-variant-numeric: tabular-nums;
	}

	#config-dialog {
		width: 90vw;
		max-width: 56rem;
	}

	#config-dialog[open] {
		animation: dialog-in 0.25s cubic-bezier(0.16, 1, 0.3, 1);
	}

	@keyframes dialog-in {
		from {
			opacity: 0;
			transform: scale(0.98) translateY(-4px);
		}
		to {
			opacity: 1;
			transform: scale(1) translateY(0);
		}
	}

	#close-config-btn:hover {
		scale: 1.05;
	}

	#close-config-btn:active {
		scale: 0.98;
	}
</style>

<script>
	import { URLStore } from '../lib/url-store';

	type InputMethod = 'point' | 'duration';
	type FinishMode = 'countup' | 'stop';
	type StopBehavior = 'freeze' | 'zero' | 'reset';
	type UnitKey = 'year' | 'month' | 'week' | 'day' | 'hour' | 'minute' | 'second' | 'millisecond';

	interface DisplayUnitSetting {
		key: UnitKey;
		template: string;
		enabled: boolean;
		breakAfter: boolean;
	}

	interface TimerConfig {
		inputMethod: InputMethod;
		targetIso: string | null;
		duration: Record<UnitKey, number>;
		displayUnits: UnitKey[];
		displaySettings: DisplayUnitSetting[];
		finishMode: FinishMode;
		stopBehavior: StopBehavior;
		started: boolean;
	}

	interface DurationBreakdown {
		year: number;
		month: number;
		week: number;
		day: number;
		hour: number;
		minute: number;
		second: number;
		millisecond: number;
	}

	const UNIT_LABELS: Record<UnitKey, string> = {
		year: '年',
		month: '月',
		week: '週',
		day: '日',
		hour: '時',
		minute: '分',
		second: '秒',
		millisecond: '毫秒',
	};

	const ORDER: UnitKey[] = ['year', 'month', 'week', 'day', 'hour', 'minute', 'second', 'millisecond'];
	const MS = {
		week: 7 * 24 * 60 * 60 * 1000,
		day: 24 * 60 * 60 * 1000,
		hour: 60 * 60 * 1000,
		minute: 60 * 1000,
		second: 1000,
	};

	const defaultDisplaySettings: DisplayUnitSetting[] = [
		{ key: 'year', template: '%Y 年', enabled: true, breakAfter: false },
		{ key: 'month', template: '%M 月', enabled: true, breakAfter: false },
		{ key: 'week', template: '%W 週', enabled: true, breakAfter: false },
		{ key: 'day', template: '%D 日', enabled: true, breakAfter: true },
		{ key: 'hour', template: '%h 時', enabled: true, breakAfter: false },
		{ key: 'minute', template: '%m 分', enabled: true, breakAfter: false },
		{ key: 'second', template: '%s 秒', enabled: true, breakAfter: true },
		{ key: 'millisecond', template: '%ms 毫秒', enabled: false, breakAfter: false },
	];

	const PRESETS: Record<string, DisplayUnitSetting[]> = {
		preset1: [
			{ key: 'year', template: '%Y 年', enabled: true, breakAfter: false },
			{ key: 'month', template: '%M 月', enabled: true, breakAfter: false },
			{ key: 'week', template: '%W 週', enabled: true, breakAfter: false },
			{ key: 'day', template: '%D 日', enabled: true, breakAfter: true },
			{ key: 'hour', template: '%h 時', enabled: true, breakAfter: false },
			{ key: 'minute', template: '%m 分', enabled: true, breakAfter: false },
			{ key: 'second', template: '%s 秒', enabled: true, breakAfter: true },
			{ key: 'millisecond', template: '%ms 毫秒', enabled: true, breakAfter: false },
		],
		preset2: [
			{ key: 'year', template: '%Y/', enabled: true, breakAfter: false },
			{ key: 'month', template: '%M/', enabled: true, breakAfter: false },
			{ key: 'week', template: '%W', enabled: false, breakAfter: false },
			{ key: 'day', template: '%D', enabled: true, breakAfter: true },
			{ key: 'hour', template: '%h:', enabled: true, breakAfter: false },
			{ key: 'minute', template: '%m:', enabled: true, breakAfter: false },
			{ key: 'second', template: '%s', enabled: true, breakAfter: false },
			{ key: 'millisecond', template: '.%ms', enabled: false, breakAfter: false },
		],
		preset3: [
			{ key: 'year', template: '%Y 年', enabled: false, breakAfter: false },
			{ key: 'month', template: '%M 月', enabled: false, breakAfter: false },
			{ key: 'week', template: '%W 週', enabled: false, breakAfter: false },
			{ key: 'day', template: '%D 日', enabled: true, breakAfter: true },
			{ key: 'hour', template: '%h 時', enabled: true, breakAfter: false },
			{ key: 'minute', template: '%m 分', enabled: true, breakAfter: false },
			{ key: 'second', template: '%s 秒', enabled: true, breakAfter: false },
			{ key: 'millisecond', template: '.%ms 毫秒', enabled: false, breakAfter: false },
		],
		preset4: [
			{ key: 'year', template: '%Y 年', enabled: false, breakAfter: false },
			{ key: 'month', template: '%M 月', enabled: false, breakAfter: false },
			{ key: 'week', template: '%W 週', enabled: false, breakAfter: false },
			{ key: 'day', template: '%D 日', enabled: false, breakAfter: false },
			{ key: 'hour', template: '%h 時', enabled: true, breakAfter: false },
			{ key: 'minute', template: '%m 分', enabled: true, breakAfter: false },
			{ key: 'second', template: '%s 秒', enabled: true, breakAfter: false },
			{ key: 'millisecond', template: '%ms 毫秒', enabled: false, breakAfter: false },
		],
		preset5: [
			{ key: 'year', template: '%Y 年', enabled: true, breakAfter: false },
			{ key: 'month', template: '%M 月', enabled: true, breakAfter: false },
			{ key: 'week', template: '%W 週', enabled: false, breakAfter: false },
			{ key: 'day', template: '%D 日', enabled: true, breakAfter: false },
			{ key: 'hour', template: '%h 時', enabled: false, breakAfter: false },
			{ key: 'minute', template: '%m 分', enabled: false, breakAfter: false },
			{ key: 'second', template: '%s 秒', enabled: false, breakAfter: false },
			{ key: 'millisecond', template: '%ms 毫秒', enabled: false, breakAfter: false },
		],
		preset6: [
			{ key: 'year', template: '%Y 年', enabled: false, breakAfter: false },
			{ key: 'month', template: '%M 月', enabled: false, breakAfter: false },
			{ key: 'week', template: '%W 週', enabled: false, breakAfter: false },
			{ key: 'day', template: '%D 日', enabled: false, breakAfter: false },
			{ key: 'hour', template: '%h 時', enabled: false, breakAfter: false },
			{ key: 'minute', template: '%m 分', enabled: false, breakAfter: false },
			{ key: 'second', template: '%s 秒', enabled: false, breakAfter: false },
			{ key: 'millisecond', template: '%ms 毫秒', enabled: true, breakAfter: false },
		],
	};

	const defaultFuture = new Date();
	defaultFuture.setHours(defaultFuture.getHours() + 1, 0, 0, 0);

	const defaultConfig: TimerConfig = {
		inputMethod: 'point',
		targetIso: defaultFuture.toISOString(),
		duration: {
			year: 0,
			month: 0,
			week: 0,
			day: 0,
			hour: 0,
			minute: 0,
			second: 0,
			millisecond: 0,
		},
		displayUnits: ['year', 'month', 'week', 'day', 'hour', 'minute', 'second'],
		displaySettings: structuredClone(defaultDisplaySettings),
		finishMode: 'countup',
		stopBehavior: 'freeze',
		started: false,
	};

	const store = new URLStore<TimerConfig>(defaultConfig);

	const els = {
		displayValue: document.getElementById('display-value') as HTMLDivElement,
		displayMeta: document.getElementById('display-meta') as HTMLDivElement,
		doneBehaviorHint: document.getElementById('done-behavior-hint') as HTMLDivElement,
		methodButtons: Array.from(document.querySelectorAll('.method-btn')) as HTMLButtonElement[],
		panelPoint: document.getElementById('panel-point') as HTMLDivElement,
		panelDuration: document.getElementById('panel-duration') as HTMLDivElement,
		pointInput: document.getElementById('point-input') as HTMLInputElement,
		resetBtn: document.getElementById('reset-btn') as HTMLButtonElement,
		editConfigBtn: document.getElementById('edit-config-btn') as HTMLButtonElement,
		stopBehaviorWrap: document.getElementById('stop-behavior-wrap') as HTMLDivElement,
		configDialog: document.getElementById('config-dialog') as HTMLDialogElement,
		durationInputs: {
			year: document.getElementById('dur-year') as HTMLInputElement,
			month: document.getElementById('dur-month') as HTMLInputElement,
			week: document.getElementById('dur-week') as HTMLInputElement,
			day: document.getElementById('dur-day') as HTMLInputElement,
			hour: document.getElementById('dur-hour') as HTMLInputElement,
			minute: document.getElementById('dur-minute') as HTMLInputElement,
			second: document.getElementById('dur-second') as HTMLInputElement,
			millisecond: document.getElementById('dur-ms') as HTMLInputElement,
		},
		unitChecks: Array.from(document.querySelectorAll('.unit-chip input[type="checkbox"]')) as HTMLInputElement[],
		finishModeRadios: Array.from(document.querySelectorAll('input[name="finish-mode"]')) as HTMLInputElement[],
		stopBehaviorRadios: Array.from(document.querySelectorAll('input[name="stop-behavior"]')) as HTMLInputElement[],
		presetButtons: Array.from(document.querySelectorAll('.preset-btn')) as HTMLButtonElement[],
		displaySettingsGrid: document.getElementById('display-settings-grid') as HTMLDivElement,
	};

	let config = loadConfig();
	let frozenDisplay: string | null = null;
	let resetReferenceIso: string | null = null;
	let isUpdatingFromForm = false;

	function loadConfig(): TimerConfig {
		const data = store.get();
		return {
			...structuredClone(defaultConfig),
			...data,
			duration: {
				...structuredClone(defaultConfig).duration,
				...(data.duration ?? {}),
			},
			displayUnits: Array.isArray(data.displayUnits) && data.displayUnits.length > 0
				? data.displayUnits.filter((u): u is UnitKey => ORDER.includes(u as UnitKey))
				: structuredClone(defaultConfig).displayUnits,
			displaySettings: Array.isArray(data.displaySettings) && data.displaySettings.length > 0
				? data.displaySettings
					.filter((s): s is DisplayUnitSetting => ORDER.includes(s.key))
					.map((s) => ({
						...s,
						breakAfter: Boolean(s.breakAfter),
					}))
				: structuredClone(defaultConfig).displaySettings,
		};
	}

	function saveConfig() {
		store.set(config);
	}

	function pad(n: number, size = 2) {
		return String(n).padStart(size, '0');
	}

	function toLocalInputValue(date: Date) {
		return [
			date.getFullYear(),
			pad(date.getMonth() + 1),
			pad(date.getDate()),
		].join('-') + 'T' + [pad(date.getHours()), pad(date.getMinutes())].join(':');
	}

	function addCalendarDuration(base: Date, duration: Record<UnitKey, number>) {
		const d = new Date(base.getTime());
		if (duration.year) d.setFullYear(d.getFullYear() + duration.year);
		if (duration.month) d.setMonth(d.getMonth() + duration.month);
		const extraDays = (duration.week || 0) * 7 + (duration.day || 0);
		if (extraDays) d.setDate(d.getDate() + extraDays);
		if (duration.hour) d.setHours(d.getHours() + duration.hour);
		if (duration.minute) d.setMinutes(d.getMinutes() + duration.minute);
		if (duration.second) d.setSeconds(d.getSeconds() + duration.second);
		if (duration.millisecond) d.setMilliseconds(d.getMilliseconds() + duration.millisecond);
		return d;
	}

	function diffCalendar(from: Date, to: Date): DurationBreakdown {
		const forward = to.getTime() >= from.getTime();
		let start = forward ? new Date(from.getTime()) : new Date(to.getTime());
		const end = forward ? new Date(to.getTime()) : new Date(from.getTime());

		const out: DurationBreakdown = {
			year: 0,
			month: 0,
			week: 0,
			day: 0,
			hour: 0,
			minute: 0,
			second: 0,
			millisecond: 0,
		};

		while (true) {
			const next = new Date(start.getTime());
			next.setFullYear(next.getFullYear() + 1);
			if (next <= end) {
				out.year++;
				start = next;
			} else break;
		}

		while (true) {
			const next = new Date(start.getTime());
			next.setMonth(next.getMonth() + 1);
			if (next <= end) {
				out.month++;
				start = next;
			} else break;
		}

		let rest = end.getTime() - start.getTime();
		out.week = Math.floor(rest / MS.week);
		rest -= out.week * MS.week;
		out.day = Math.floor(rest / MS.day);
		rest -= out.day * MS.day;
		out.hour = Math.floor(rest / MS.hour);
		rest -= out.hour * MS.hour;
		out.minute = Math.floor(rest / MS.minute);
		rest -= out.minute * MS.minute;
		out.second = Math.floor(rest / MS.second);
		rest -= out.second * MS.second;
		out.millisecond = rest;

		return out;
	}

	function rebalanceForSelection(diff: DurationBreakdown, selection: UnitKey[]) {
		const map: DurationBreakdown = { ...diff };

		if (!selection.includes('month')) {
			map.week += Math.floor(map.month * 30.436875 / 7);
			map.day += Math.round((map.month * 30.436875) % 7);
			map.month = 0;
		}

		if (!selection.includes('week')) {
			map.day += map.week * 7;
			map.week = 0;
		}

		if (!selection.includes('day')) {
			map.hour += map.day * 24;
			map.day = 0;
		}

		if (!selection.includes('hour')) {
			map.minute += map.hour * 60;
			map.hour = 0;
		}

		if (!selection.includes('minute')) {
			map.second += map.minute * 60;
			map.minute = 0;
		}

		if (!selection.includes('second')) {
			map.millisecond += map.second * 1000;
			map.second = 0;
		}

		if (!selection.includes('year')) {
			map.month += map.year * 12;
			map.year = 0;
		}

		if (!selection.includes('month')) {
			map.week += Math.floor(map.month * 30.436875 / 7);
			map.day += Math.round((map.month * 30.436875) % 7);
			map.month = 0;
		}

		if (!selection.includes('millisecond')) {
			map.second += Math.floor(map.millisecond / 1000);
			map.millisecond = map.millisecond % 1000;
		}

		return map;
	}

	function buildDisplay(diff: DurationBreakdown, settings: DisplayUnitSetting[]) {
		const enabledSettings = settings.filter((s) => s.enabled);
		if (enabledSettings.length === 0) return '0';

		const selectedKeys = enabledSettings.map((s) => s.key);
		const rebalance = rebalanceForSelection(diff, selectedKeys);

		const lines: string[][] = [];
		let currentLine: string[] = [];

		for (const setting of enabledSettings) {
			const value = rebalance[setting.key];
			let result = setting.template;

			if (setting.key === 'millisecond') {
				result = result.replaceAll('%ms', String(value).padStart(3, '0'));
			} else if (setting.key === 'hour') {
				result = result.replaceAll('%h', String(value).padStart(2, '0'));
			} else if (setting.key === 'minute') {
				result = result.replaceAll('%m', String(value).padStart(2, '0'));
			} else if (setting.key === 'second') {
				result = result.replaceAll('%s', String(value).padStart(2, '0'));
			} else if (setting.key === 'year') {
				result = result.replaceAll('%Y', String(value));
			} else if (setting.key === 'month') {
				result = result.replaceAll('%M', String(value));
			} else if (setting.key === 'week') {
				result = result.replaceAll('%W', String(value));
			} else if (setting.key === 'day') {
				result = result.replaceAll('%D', String(value));
			}

			currentLine.push(result);

			if (setting.breakAfter) {
				lines.push(currentLine);
				currentLine = [];
			}
		}

		if (currentLine.length > 0) {
			lines.push(currentLine);
		}

		return lines.map((line) => line.join(' ')).join('<br/>');
	}

	function setMethod(method: InputMethod) {
		config.inputMethod = method;
		els.methodButtons.forEach((btn) => {
			btn.dataset.active = String(btn.dataset.method === method);
		});
		els.panelPoint.classList.toggle('hidden', method !== 'point');
		els.panelDuration.classList.toggle('hidden', method !== 'duration');
	}

	function renderDisplaySettingsUI() {
		els.displaySettingsGrid.innerHTML = '';

		for (const setting of config.displaySettings) {
			const item = document.createElement('div');
			item.className = 'display-settings-item';

			const checkboxLabel = document.createElement('label');
			const checkbox = document.createElement('input');
			checkbox.type = 'checkbox';
			checkbox.checked = setting.enabled;
			checkbox.dataset.unitKey = setting.key;
			checkboxLabel.appendChild(checkbox);
			checkboxLabel.appendChild(document.createTextNode(UNIT_LABELS[setting.key]));

			const breakLabel = document.createElement('label');
			breakLabel.className = 'display-settings-break';

			const breakCheckbox = document.createElement('input');
			breakCheckbox.type = 'checkbox';
			breakCheckbox.checked = Boolean(setting.breakAfter);
			breakCheckbox.dataset.unitKey = setting.key;

			const breakText = document.createElement('span');
			breakText.textContent = '換行';

			breakLabel.appendChild(breakCheckbox);
			breakLabel.appendChild(breakText);

			const templateInput = document.createElement('input');
			templateInput.type = 'text';
			templateInput.value = setting.template;
			templateInput.placeholder = `如 %${setting.key.charAt(0).toUpperCase()} 日`;
			templateInput.dataset.unitKey = setting.key;

			item.appendChild(checkboxLabel);
			item.appendChild(breakLabel);
			item.appendChild(templateInput);

			els.displaySettingsGrid.appendChild(item);

			checkbox.addEventListener('change', () => {
				const idx = config.displaySettings.findIndex((s) => s.key === setting.key);
				if (idx !== -1) {
					config.displaySettings[idx].enabled = checkbox.checked;
					isUpdatingFromForm = true;
					saveConfig();
					isUpdatingFromForm = false;
					render();
				}
			});

			templateInput.addEventListener('input', () => {
				const idx = config.displaySettings.findIndex((s) => s.key === setting.key);
				if (idx !== -1) {
					config.displaySettings[idx].template = templateInput.value;
					isUpdatingFromForm = true;
					saveConfig();
					isUpdatingFromForm = false;
					render();
				}
			});

			breakCheckbox.addEventListener('change', () => {
				const idx = config.displaySettings.findIndex((s) => s.key === setting.key);
				if (idx !== -1) {
					config.displaySettings[idx].breakAfter = breakCheckbox.checked;
					isUpdatingFromForm = true;
					saveConfig();
					isUpdatingFromForm = false;
					render();
				}
			});
		}
	}

	function syncForm(shouldRenderDisplaySettings = true) {
		setMethod(config.inputMethod);

		if (config.targetIso) {
			const d = new Date(config.targetIso);
			if (!Number.isNaN(d.getTime())) {
				els.pointInput.value = toLocalInputValue(d);
			}
		}

		for (const key of ORDER) {
			if (key in els.durationInputs) {
				const input = els.durationInputs[key as keyof typeof els.durationInputs];
				if (input) input.value = String(config.duration[key] ?? 0);
			}
		}

		els.unitChecks.forEach((checkbox) => {
			checkbox.checked = config.displayUnits.includes(checkbox.value as UnitKey);
		});

		els.finishModeRadios.forEach((radio) => {
			radio.checked = radio.value === config.finishMode;
		});
		els.stopBehaviorRadios.forEach((radio) => {
			radio.checked = radio.value === config.stopBehavior;
		});

		if (shouldRenderDisplaySettings) {
			renderDisplaySettingsUI();
		}
		updateFinishBehaviorUI();
	}

	function updateFinishBehaviorUI() {
		els.stopBehaviorWrap.classList.toggle('hidden', config.finishMode !== 'stop');
	}

	function resetAll() {
		config = structuredClone(defaultConfig);
		frozenDisplay = null;
		resetReferenceIso = null;
		syncForm();
		saveConfig();
		render();
	}

	function applyPreset(presetKey: string) {
		const preset = PRESETS[presetKey];
		if (preset) {
			config.displaySettings = structuredClone(preset);
			saveConfig();
			syncForm();
			render();
			updatePresetButtonUI();
		}
	}

	function updatePresetButtonUI() {
		els.presetButtons.forEach((btn) => {
			btn.dataset.active = 'false';
		});
	}

	function formatMeta(target: Date, isFuture: boolean) {
		const modeText = isFuture ? '倒數中' : '正數中';
		return `${modeText} · 目標時間 ${target.toLocaleString('zh-TW')}`;
	}

	function render() {
		if (!config.started || !config.targetIso) {
			els.displayValue.textContent = '請先完成設定';
			els.displayMeta.textContent = '尚未指定時間點';
			els.displayValue.classList.remove('blinking');
			els.doneBehaviorHint.classList.add('hidden');
			els.displayMeta.classList.remove('hidden');
			return;
		}

		const now = new Date();
		const target = new Date(config.targetIso);
		if (Number.isNaN(target.getTime())) {
			els.displayValue.textContent = '時間格式錯誤';
			return;
		}

		const rawDiff = target.getTime() - now.getTime();
		const isCountdown = rawDiff > 0;
		const hasReached = rawDiff <= 0;

		els.displayValue.classList.remove('blinking');
		els.doneBehaviorHint.classList.add('hidden');
		els.displayMeta.classList.remove('hidden');

		if (isCountdown) {
			const breakdown = diffCalendar(now, target);
			els.displayValue.innerHTML = buildDisplay(breakdown, config.displaySettings);
			els.displayMeta.textContent = formatMeta(target, true);
			return;
		}

		if (hasReached && config.finishMode === 'stop') {
			els.doneBehaviorHint.classList.remove('hidden');
			els.displayMeta.classList.add('hidden');

			if (config.stopBehavior === 'freeze') {
				if (!frozenDisplay) {
					const exactTarget = new Date(target.getTime());
					const breakdown = diffCalendar(exactTarget, exactTarget);
					frozenDisplay = buildDisplay(breakdown, config.displaySettings);
				}
				els.displayValue.innerHTML = frozenDisplay;
				els.displayValue.classList.add('blinking');
				els.doneBehaviorHint.textContent = '已達時間點 · 閃爍';
				return;
			}

			if (config.stopBehavior === 'zero') {
				els.displayValue.innerHTML = buildDisplay({
					year: 0,
					month: 0,
					week: 0,
					day: 0,
					hour: 0,
					minute: 0,
					second: 0,
					millisecond: 0,
				}, config.displaySettings);
				els.doneBehaviorHint.textContent = '已達時間點 · 歸零';
				return;
			}

			if (config.stopBehavior === 'reset') {
				const nowForReset = new Date();
				const nextTarget = addCalendarDuration(nowForReset, config.duration);
				config.targetIso = nextTarget.toISOString();
				saveConfig();
				els.doneBehaviorHint.textContent = '已達時間點 · 已重置';
				return;
			}
		}

		const breakdown = diffCalendar(target, now);
		const lines = buildDisplay(breakdown, config.displaySettings).split('<br/>');
		if (lines.length >= 2) {
			lines[1] = '+' + lines[1];
		} else {
			lines[0] = '+' + lines[0];
		}
		els.displayValue.innerHTML = lines.join('<br/>');
		els.displayMeta.textContent = formatMeta(target, false);
	}

	store.subscribe((newConfig) => {
		if (!isUpdatingFromForm) {
			config = newConfig;
			syncForm(true);
		} else {
			config = newConfig;
		}
		render();
	});

	els.methodButtons.forEach((btn) => {
		btn.addEventListener('click', () => {
			const method = btn.dataset.method as InputMethod;
			config.inputMethod = method;
			setMethod(method);
			saveConfig();
		});
	});

	els.finishModeRadios.forEach((radio) => {
		radio.addEventListener('change', () => {
			config.finishMode = radio.value as FinishMode;
			updateFinishBehaviorUI();
			saveConfig();
		});
	});

	els.stopBehaviorRadios.forEach((radio) => {
		radio.addEventListener('change', () => {
			config.stopBehavior = radio.value as StopBehavior;
			saveConfig();
		});
	});

	els.resetBtn.addEventListener('click', resetAll);

	els.editConfigBtn.addEventListener('click', () => {
		els.configDialog.showModal();
	});

	const closeConfigBtn = document.getElementById('close-config-btn') as HTMLButtonElement;
	closeConfigBtn.addEventListener('click', () => {
		els.configDialog.close();
	});

	els.configDialog.addEventListener('click', (e) => {
		if (e.target === els.configDialog) {
			els.configDialog.close();
		}
	});

	els.presetButtons.forEach((btn) => {
		btn.addEventListener('click', () => {
			const preset = btn.dataset.preset;
			if (preset) applyPreset(preset);
		});
	});

	els.pointInput.addEventListener('change', () => {
		const value = els.pointInput.value;
		config.targetIso = value ? new Date(value).toISOString() : null;
		if (!config.started && config.targetIso) {
			config.started = true;
			resetReferenceIso = config.targetIso;
		}
		saveConfig();
		render();
	});

	const durationKeys: UnitKey[] = ['year', 'month', 'week', 'day', 'hour', 'minute', 'second', 'millisecond'];
	for (const key of durationKeys) {
		const input = els.durationInputs[key as keyof typeof els.durationInputs];
		if (input) {
			input.addEventListener('change', () => {
				for (const k of durationKeys) {
					const i = els.durationInputs[k as keyof typeof els.durationInputs];
					if (i) config.duration[k] = Math.max(0, Number.parseInt(i.value || '0', 10) || 0);
				}
				const now = new Date();
				config.targetIso = addCalendarDuration(now, config.duration).toISOString();
				if (!config.started) {
					config.started = true;
					resetReferenceIso = config.targetIso;
				}
				saveConfig();
				render();
			});
		}
	}

	syncForm();
	render();

	function loop() {
		render();
		requestAnimationFrame(loop);
	}
	loop();
</script>
