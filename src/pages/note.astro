---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Note">
	<div class="container">
		<textarea id="note-area" placeholder="Start typing..." spellcheck="false"></textarea>
	</div>
</Layout>

<script>
	import { URLStore } from '../lib/url-store';

	const store = new URLStore<string>('');
	const textarea = document.getElementById('note-area') as HTMLTextAreaElement;

	if (textarea) {
		// Initialize value from URL
		const initialValue = store.get();
		if (initialValue) {
			textarea.value = initialValue;
		}

		// Update URL on input
		textarea.addEventListener('input', () => {
			store.set(textarea.value);
		});

		// Subscribe to external changes (e.g. browser navigation)
		store.subscribe((val) => {
			if (textarea.value !== val) {
				textarea.value = val;
			}
		});
	}
</script>

<style>
	.container {
		display: flex;
		flex-direction: column;
		height: 100vh;
		width: 100vw;
		margin: 0;
		padding: 0;
		overflow: hidden;
	}

	textarea {
		flex: 1;
		width: 100%;
		height: 100%;
		padding: 1rem;
		border: none;
		border-radius: 0;
		font-family:
			'Menlo',
			'Monaco',
			'Consolas',
			'Courier New',
			monospace;
		font-size: 1rem;
		resize: none;
		outline: none;
		background-color: #fff;
		color: #333;
		line-height: 1.6;
		box-sizing: border-box;
	}

	@media (prefers-color-scheme: dark) {
		:global(body) {
			background-color: #111;
		}

		textarea {
			background-color: #111;
			color: #eee;
		}
	}
</style>
